# ============================================================
# CalZarte — Configuración de entorno (plantilla)
# ============================================================
# Copiar a .env y ajustar valores.

# --- Base de datos ---
# Motor actual: sqlite  |  Futuro: postgresql
DB_DRIVER=sqlite

# SQLite: ruta al archivo de base de datos
DATABASE_URL=calzarte.db

# PostgreSQL (descomentar cuando se migre):
# DB_DRIVER=postgresql
# DATABASE_URL=postgresql://usuario:password@localhost:5432/calzarte

# --- Aplicación ---
NODE_ENV=development
PORT=3000
